# ============================================================
# GraphBit Backend — required environment variables
# Copy to .env and fill in your values
# ============================================================

# PostgreSQL connection string (required)
DATABASE_URL=postgresql+psycopg://graphbit:graphbit@localhost:5432/graphbit

# JWT signing secret (required — change in production!)
SECRET_KEY=change-me-to-a-random-string

# Google Gemini API key (required for QA, embeddings, topic extraction)
GEMINI_API_KEY=your-gemini-api-key-here

# --- PostgreSQL Database Configuration ---
# These values are used by the 'postgres' service in docker-compose.yml
# and also to construct the DATABASE_URL below.
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=nocodeml_db

# --- Application Configuration ---
# These values are read by app/core/config.py

# Full database connection string for SQLAlchemy (Async)
# Format: postgresql+<driver>://<user>:<password>@<host>:<port>/<db_name>
# We use 'postgres' as the host because that's the service name in docker-compose.
DATABASE_URL=postgresql+psycopg://myuser:mysecretpassword@postgres:5432/nocodeml_db

# Connection strings for Celery to use Redis
# We use 'redis' as the host because that's the service name in docker-compose.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Secret key for signing JWTs for fastapi-users.
# IMPORTANT: Change this to a long, random string for a real project.
# You can generate one with: openssl rand -hex 32
SECRET_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2


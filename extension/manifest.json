{
  "manifest_version": 3,
  "name": "Graphbit Material Capture",
  "version": "0.1.0",
  "description": "Capture YouTube links and HTML page content as Graphbit materials.",
  "action": {
    "default_title": "Add to Graphbit",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://www.youtube.com/*",
    "https://youtu.be/*",
    "file:///*",
    "<all_urls>"
  ]
}
